<?xml version="1.0" encoding="utf-8"?>
<!-- The dashboard server is plain HTTP on the LAN and its address is
     user-configurable in Settings, so cleartext must be allowed globally. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
